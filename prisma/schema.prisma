generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// CHANNELS (top-level entity — each "ours" channel is a profile)
// ─────────────────────────────────────────────
model Channel {
  id              String    @id @default(cuid())
  parentChannelId String?
  parentChannel   Channel?  @relation("ChannelCompetitors", fields: [parentChannelId], references: [id], onDelete: Cascade)
  competitors     Channel[] @relation("ChannelCompetitors")
  youtubeId       String    @unique
  handle          String
  nameAr          String
  nameEn          String?
  type            String    @default("ours")
  avatarUrl       String?
  status          String    @default("active")
  subscribers     BigInt    @default(0)
  totalViews      BigInt    @default(0)
  videoCount      Int       @default(0)
  uploadCadence   Float?
  lastFetchedAt   DateTime?
  startHook       String?
  endHook         String?
  nationality     String?
  color           String    @default("#3b82f6")
  lastStatsRefreshAt  DateTime?
  rescoreIntervalHours Int?  @default(24)
  videos          Video[]
  snapshots       ChannelSnapshot[]
  stories         Story[]
  articleSources  ArticleSource[]
  scoreProfile    ScoreProfile?
  alerts          Alert[]
  galleryMedia    GalleryMedia[]
  galleryAlbums   GalleryAlbum[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([parentChannelId])
  @@index([type, status, parentChannelId])
}

model ChannelSnapshot {
  id          String   @id @default(cuid())
  channelId   String
  channel     Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  subscribers BigInt
  totalViews  BigInt
  videoCount  Int
  avgViews    Int
  engagement  Float
  snapshotAt  DateTime @default(now())
  @@index([channelId, snapshotAt])
}

// ─────────────────────────────────────────────
// DIALECTS (per country, per AI engine)
// ─────────────────────────────────────────────
model Dialect {
  id          String   @id @default(cuid())
  countryCode String
  engine      String   @default("claude")
  name        String
  short       String
  long        String

  @@unique([countryCode, engine])
  @@index([engine])
}

// ─────────────────────────────────────────────
// VIDEOS
// ─────────────────────────────────────────────
model Video {
  id            String        @id @default(cuid())
  channelId     String
  channel       Channel       @relation(fields: [channelId], references: [id], onDelete: Cascade)
  youtubeId     String        @unique
  titleAr       String?
  titleEn       String?
  description   String?       @db.Text
  publishedAt   DateTime?
  viewCount     BigInt        @default(0)
  likeCount     BigInt        @default(0)
  commentCount  BigInt        @default(0)
  duration      String?
  videoType     String    @default("video")
  thumbnailUrl  String?
  transcription String?       @db.Text
  analysisResult Json?
  omitFromAnalytics Boolean   @default(false)
  embedding     Unsupported("vector(1536)")?
  pipelineItem  PipelineItem?
  producedStory Story?        @relation("StoryProducedVideo")
  comments      Comment[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([channelId])
  @@index([publishedAt])
  @@index([channelId, publishedAt])
  @@index([channelId, viewCount])
}

// ─────────────────────────────────────────────
// PIPELINE
// ─────────────────────────────────────────────
model PipelineItem {
  id         String    @id @default(cuid())
  videoId    String    @unique
  video      Video     @relation(fields: [videoId], references: [id], onDelete: Cascade)
  stage      String    @default("import")
  status     String    @default("queued")
  retries    Int       @default(0)
  error      String?
  result     Json?
  lastStage  String?
  startedAt  DateTime?
  finishedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([stage, status])
}

// ─────────────────────────────────────────────
// COMMENTS
// ─────────────────────────────────────────────
model Comment {
  id          String    @id @default(cuid())
  videoId     String
  video       Video     @relation(fields: [videoId], references: [id], onDelete: Cascade)
  youtubeId   String    @unique
  text        String    @db.Text
  authorName  String?
  likeCount   Int       @default(0)
  publishedAt DateTime?
  sentiment   String?
  createdAt   DateTime  @default(now())

  @@index([videoId])
  @@index([videoId, likeCount(sort: Desc)])
}

// ─────────────────────────────────────────────
// STORIES
// ─────────────────────────────────────────────
model Story {
  id              String     @id @default(cuid())
  channelId       String
  channel         Channel    @relation(fields: [channelId], references: [id], onDelete: Cascade)
  headline        String
  origin          String     @default("ai")
  stage           String     @default("suggestion")
  coverageStatus  String?
  sourceUrl       String?
  sourceName      String?
  sourceDate      DateTime?
  relevanceScore  Int?
  viralScore      Int?
  firstMoverScore Int?
  compositeScore  Float?
  scriptLong      String?    @db.Text
  scriptShort     String?    @db.Text
  brief           Json?
  producedVideoId String?    @unique
  producedVideo   Video?     @relation("StoryProducedVideo", fields: [producedVideoId], references: [id], onDelete: SetNull)
  embedding       Unsupported("vector(1536)")?
  lastRescoredAt  DateTime?
  rescoreLog      Json?
  log             StoryLog[]
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  queryVersion    String?

  @@index([channelId, stage])
  @@index([channelId, compositeScore])
  @@index([channelId, createdAt])
  @@index([channelId, lastRescoredAt])
}

model StoryLog {
  id        String   @id @default(cuid())
  storyId   String
  story     Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  action    String
  note      String?
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@index([storyId])
}

// ─────────────────────────────────────────────
// USERS & AUTH
// ─────────────────────────────────────────────
model User {
  id            String     @id @default(cuid())
  email         String     @unique
  name          String?
  avatarUrl     String?
  googleId      String?    @unique
  role          String     @default("viewer")
  note          String?
  isActive      Boolean    @default(true)
  pageAccess    Json?
  channelAccess Json?
  storyLogs     StoryLog[]
  uploadedMedia GalleryMedia[] @relation("GalleryMediaUploadedBy")
  createdAlbums GalleryAlbum[] @relation("GalleryAlbumCreatedBy")
  sessions      Session[]
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}

enum MediaType {
  PHOTO
  VIDEO
}

model GalleryAlbum {
  id          String        @id @default(cuid())
  channelId   String
  channel     Channel       @relation(fields: [channelId], references: [id], onDelete: Cascade)
  name        String
  description String?
  coverMediaId String?
  coverMedia  GalleryMedia? @relation("GalleryAlbumCover", fields: [coverMediaId], references: [id], onDelete: SetNull)
  media       GalleryMedia[]
  createdById String
  createdBy   User          @relation("GalleryAlbumCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([channelId, createdAt(sort: Desc)])
  @@index([coverMediaId])
}

model GalleryMedia {
  id             String        @id @default(cuid())
  channelId      String
  channel        Channel       @relation(fields: [channelId], references: [id], onDelete: Cascade)
  albumId        String?
  album          GalleryAlbum? @relation(fields: [albumId], references: [id], onDelete: SetNull)
  type           MediaType
  fileName       String
  fileSize       BigInt
  mimeType       String
  width          Int?
  height         Int?
  duration       Float?
  r2Key          String        @unique
  r2Url          String
  thumbnailR2Key String?
  thumbnailR2Url String?
  metadata       Json?
  uploadedById   String
  uploadedBy     User          @relation("GalleryMediaUploadedBy", fields: [uploadedById], references: [id], onDelete: Cascade)
  albumCoverFor  GalleryAlbum[] @relation("GalleryAlbumCover")
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([channelId, createdAt(sort: Desc)])
  @@index([albumId, createdAt(sort: Desc)])
  @@index([uploadedById])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([token])
  @@index([userId])
  @@index([expiresAt])
}

// ─────────────────────────────────────────────
// API KEYS (encrypted at rest — global, shared across all profiles)
// ─────────────────────────────────────────────
model ApiKey {
  id           String    @id @default(cuid())
  service      String    @unique
  encryptedKey String    @db.Text
  isActive     Boolean   @default(true)
  lastUsedAt   DateTime?
  usageCount   Int       @default(0)
  quotaLimit   Int?
  quotaUsed    Int       @default(0)
  quotaResetAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

// ─────────────────────────────────────────────
// API USAGE LOG (one row per external API call)
// ─────────────────────────────────────────────
model ApiUsage {
  id         String   @id @default(cuid())
  channelId  String
  service    String
  action     String?
  tokensUsed Int?
  status     String   @default("ok")
  error      String?  @db.Text
  createdAt  DateTime @default(now())

  @@index([channelId, createdAt(sort: Desc)])
  @@index([service])
}

model YoutubeApiKey {
  id           String    @id @default(cuid())
  label        String    @default("Key 1")
  encryptedKey String    @db.Text
  isActive     Boolean   @default(true)
  lastUsedAt   DateTime?
  usageCount   Int       @default(0)
  sortOrder    Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([isActive])
}

// ─────────────────────────────────────────────
// Article Sources & Article Pipeline
// ─────────────────────────────────────────────
model ArticleSource {
  id           String    @id @default(cuid())
  channelId    String
  channel      Channel   @relation(fields: [channelId], references: [id], onDelete: Cascade)
  type         String
  label        String
  config       Json
  image        String?   @db.Text
  apiKeyEncrypted String? @db.Text
  lastImportedRunId String?
  isActive     Boolean   @default(true)
  language     String    @default("en")
  lastPolledAt DateTime?
  fetchLog     Json?
  articles     Article[]
  apifyRuns    ApifyRun[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([channelId])
}

model ApifyRun {
  id         String        @id @default(cuid())
  sourceId   String
  source     ArticleSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  runId      String
  datasetId  String?
  startedAt  DateTime?
  finishedAt DateTime?
  itemCount  Int?
  status     String
  importedAt DateTime?
  createdAt  DateTime      @default(now())

  @@unique([sourceId, runId])
  @@index([sourceId, startedAt(sort: Desc)])
}

model Article {
  id             String        @id @default(cuid())
  channelId      String
  sourceId       String
  source         ArticleSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  url            String
  title          String?
  description    String?       @db.Text
  content        String?       @db.Text
  contentClean   String?       @db.Text
  contentAr      String?       @db.Text
  publishedAt    DateTime?
  language       String?

  stage          String        @default("imported")
  status         String        @default("queued")
  retries        Int           @default(0)
  error          String?
  startedAt      DateTime?
  finishedAt     DateTime?

  processingLog  Json?
  analysis       Json?
  relevanceScore Float?

  finalScore     Float?
  rankReason     String?

  storyId        String?

  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@unique([channelId, url])
  @@index([sourceId, stage])
  @@index([channelId, stage])
  @@index([channelId, createdAt(sort: Desc)])
  @@index([stage, status])
  @@index([storyId])
}

// ─────────────────────────────────────────────
// SCORE INTELLIGENCE: Self-Learning Profile
// ─────────────────────────────────────────────
model ScoreProfile {
  id                    String    @id @default(cuid())
  channelId             String    @unique
  channel               Channel   @relation(fields: [channelId], references: [id], onDelete: Cascade)
  weightAdjustments     Json?
  tagSignals            Json?
  contentTypeSignals    Json?
  regionSignals         Json?
  aiViralAccuracy       Float     @default(1.0)
  aiRelevanceAccuracy   Float     @default(1.0)
  nicheTags             String[]  @default([])
  nicheTagsAr           String[]  @default([])
  nicheEmbedding        Unsupported("vector(1536)")?
  nicheEmbeddingGeneratedAt DateTime?
  channelAvgViews       BigInt    @default(0)
  channelMedianViews    BigInt    @default(0)
  totalOutcomes         Int       @default(0)
  totalDecisions        Int       @default(0)
  lastLearnedAt         DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

// ─────────────────────────────────────────────
// APP SETTINGS (key-value pairs persisted across restarts)
// ─────────────────────────────────────────────
model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────
// ALERTS
// ─────────────────────────────────────────────
model Alert {
  id        String   @id @default(cuid())
  channelId String
  channel   Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  storyId   String?
  videoId   String?
  type      String
  title     String
  detail    Json?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([channelId, isRead])
  @@index([channelId, createdAt(sort: Desc)])
}
