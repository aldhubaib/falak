generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// PROJECTS
// ─────────────────────────────────────────────
model Project {
  id                          String    @id @default(cuid())
  name                        String
  nameAr                      String?
  color                       String    @default("#3b82f6")
  status                      String    @default("active")
  youtubeApiKeyEncrypted      String?   @db.Text
  anthropicApiKeyEncrypted    String?   @db.Text
  perplexityApiKeyEncrypted   String?   @db.Text
  ytTranscriptApiKeyEncrypted String?   @db.Text
  firecrawlApiKeyEncrypted    String?   @db.Text
  apifyApiKeyEncrypted        String?   @db.Text
  channels                    Channel[]
  stories                     Story[]
  articleSources              ArticleSource[]
  createdAt                   DateTime  @default(now())
  updatedAt                   DateTime  @updatedAt
}

// ─────────────────────────────────────────────
// CHANNELS
// ─────────────────────────────────────────────
model Channel {
  id            String    @id @default(cuid())
  projectId     String
  project       Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  youtubeId     String    @unique
  handle        String
  nameAr        String
  nameEn        String?
  type          String    @default("competitor")
  avatarUrl     String?
  status        String    @default("active")
  subscribers   BigInt    @default(0)
  totalViews    BigInt    @default(0)
  videoCount    Int       @default(0)
  uploadCadence Float?
  lastFetchedAt DateTime?
  startHook     String?   // Branded start hook (ours only)
  endHook       String?   // Branded end hook (ours only)
  nationality   String?   // Country code or name for channel profile
  videos        Video[]
  snapshots     ChannelSnapshot[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([projectId])
}

model ChannelSnapshot {
  id          String   @id @default(cuid())
  channelId   String
  channel     Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  subscribers BigInt
  totalViews  BigInt
  videoCount  Int
  avgViews    Int
  engagement  Float
  snapshotAt  DateTime @default(now())
  @@index([channelId, snapshotAt])
}

// ─────────────────────────────────────────────
// DIALECTS (per country, per AI engine)
// ─────────────────────────────────────────────
// Links country code to dialect labels (name, short, long) for a given AI engine.
// Channel.nationality (country code) → look up Dialect by countryCode + engine.
model Dialect {
  id          String   @id @default(cuid())
  countryCode String   // ISO 3166-1 alpha-2, or MSA for Modern Standard Arabic
  engine      String   @default("claude") // e.g. claude, openai — allows engine-specific labels later
  name        String   // e.g. الكويت
  short       String   // e.g. اللهجة الكويتية
  long        String   // e.g. Kuwaiti dialect (اللهجة الكويتية)

  @@unique([countryCode, engine])
  @@index([engine])
}

// ─────────────────────────────────────────────
// VIDEOS
// ─────────────────────────────────────────────
model Video {
  id            String        @id @default(cuid())
  channelId     String
  channel       Channel       @relation(fields: [channelId], references: [id], onDelete: Cascade)
  youtubeId     String        @unique
  titleAr       String?
  titleEn       String?
  description   String?       @db.Text
  publishedAt   DateTime?
  viewCount     BigInt        @default(0)
  likeCount     BigInt        @default(0)
  commentCount  BigInt        @default(0)
  duration      String?
  videoType     String    @default("video")  // 'video' | 'short'
  thumbnailUrl  String?
  transcription String?       @db.Text
  analysisResult Json?       // AI analysis: Part A (classify) + Part B (insights)
  omitFromAnalytics Boolean   @default(false)  // when true, excluded from Analytics page stats
  pipelineItem  PipelineItem?
  comments      Comment[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([channelId])
  @@index([publishedAt])
}

// ─────────────────────────────────────────────
// PIPELINE
// ─────────────────────────────────────────────
model PipelineItem {
  id         String    @id @default(cuid())
  videoId    String    @unique
  video      Video     @relation(fields: [videoId], references: [id], onDelete: Cascade)
  stage      String    @default("import")
  status     String    @default("queued")
  retries    Int       @default(0)
  error      String?
  result     Json?     // AI analysis output (summary, topics, etc.)
  lastStage  String?   // stage at which we started (used on retry to resume from here)
  startedAt  DateTime?
  finishedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([stage, status])
}

// ─────────────────────────────────────────────
// COMMENTS
// ─────────────────────────────────────────────
model Comment {
  id          String    @id @default(cuid())
  videoId     String
  video       Video     @relation(fields: [videoId], references: [id], onDelete: Cascade)
  youtubeId   String    @unique
  text        String    @db.Text
  authorName  String?
  likeCount   Int       @default(0)
  publishedAt DateTime?
  sentiment   String?
  createdAt   DateTime  @default(now())

  @@index([videoId])
}

// ─────────────────────────────────────────────
// STORIES
// ─────────────────────────────────────────────
model Story {
  id              String     @id @default(cuid())
  projectId       String
  project         Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  headline        String
  stage           String     @default("suggestion")
  coverageStatus  String?
  sourceUrl       String?
  sourceName      String?
  sourceDate      DateTime?
  relevanceScore  Int?
  viralScore      Int?
  firstMoverScore Int?
  compositeScore  Float?
  scriptLong      String?    @db.Text
  scriptShort     String?    @db.Text
  brief           Json?
  log             StoryLog[]
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  queryVersion    String?

  @@index([projectId, stage])
}

model StoryLog {
  id        String   @id @default(cuid())
  storyId   String
  story     Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  action    String
  note      String?
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@index([storyId])
}

// ─────────────────────────────────────────────
// USERS & AUTH
// ─────────────────────────────────────────────
model User {
  id            String     @id @default(cuid())
  email         String     @unique
  name          String?
  avatarUrl     String?
  googleId      String?    @unique
  role          String     @default("viewer")
  note          String?
  isActive      Boolean    @default(true)
  pageAccess    Json?
  projectAccess Json?
  storyLogs     StoryLog[]
  sessions      Session[]
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([token])
}

// ─────────────────────────────────────────────
// API KEYS (encrypted at rest)
// ─────────────────────────────────────────────
model ApiKey {
  id           String    @id @default(cuid())
  service      String    @unique
  encryptedKey String    @db.Text
  isActive     Boolean   @default(true)
  lastUsedAt   DateTime?
  usageCount   Int       @default(0)
  quotaLimit   Int?
  quotaUsed    Int       @default(0)
  quotaResetAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

// ─────────────────────────────────────────────
// API USAGE LOG (one row per external API call)
// ─────────────────────────────────────────────
model ApiUsage {
  id         String   @id @default(cuid())
  projectId  String
  service    String   // 'anthropic' | 'youtube-data' | 'yttranscript' | 'perplexity'
  action     String?  // e.g. 'analysis-classify', 'transcribe', 'videos', etc.
  tokensUsed Int?
  status     String   @default("ok")  // 'ok' | 'fail'
  error      String?  @db.Text
  createdAt  DateTime @default(now())

  @@index([projectId, createdAt(sort: Desc)])
  @@index([service])
}

// Multiple YouTube API keys (quota rotation: when one runs out, use next)
model YoutubeApiKey {
  id           String    @id @default(cuid())
  label        String    @default("Key 1")
  encryptedKey String    @db.Text
  isActive     Boolean   @default(true)
  lastUsedAt   DateTime?
  usageCount   Int       @default(0)
  sortOrder    Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([isActive])
}

// ─────────────────────────────────────────────
// BRAIN V2: Topic Memory (learning from analyzed videos)
// ─────────────────────────────────────────────
model TopicMemory {
  id                String    @id @default(cuid())
  projectId         String
  topicKey          String    // normalized canonical key
  topicLabel        String?   // most recent human-readable label
  winsCount         Int       @default(0)
  lateCount         Int       @default(0)
  videosCount       Int       @default(0)
  viewsSum          BigInt    @default(0)
  performanceScore  Float     @default(0)
  weight            Float     @default(0)
  lastOutcomeAt     DateTime?
  lastSeenAt        DateTime  @default(now())
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  demandScore       Float     @default(0)
  winsShort         Float     @default(0)
  winsLong          Float     @default(0)
  velocityScore     Float     @default(0)

  @@unique([projectId, topicKey])
  @@index([projectId])
  @@index([projectId, weight])
  @@index([projectId, lastSeenAt])
}

model TopicMemoryEvent {
  id         String   @id @default(cuid())
  projectId  String
  videoId    String
  topicKey   String
  outcome    String   // 'gap_win' | 'late'
  views      BigInt   @default(0)
  occurredAt DateTime @default(now())

  @@unique([videoId, topicKey, outcome])
  @@index([projectId, occurredAt])
}

// ─────────────────────────────────────────────
// BRAIN V3: Article Sources & Article Pipeline
// ─────────────────────────────────────────────
model ArticleSource {
  id           String    @id @default(cuid())
  projectId    String
  project      Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  type         String    // rss | apify_actor
  label        String
  config       Json      // source config + optional search filters + source budget
  apiKeyEncrypted String? @db.Text
  lastImportedRunId String?
  isActive     Boolean   @default(true)
  language     String    @default("en")
  lastPolledAt DateTime?
  fetchLog     Json?     // array of { time, raw, gated, dupes, inserted, error }
  articles     Article[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([projectId])
}

model Article {
  id             String        @id @default(cuid())
  projectId      String
  sourceId       String
  source         ArticleSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  url            String
  title          String?
  description    String?       @db.Text
  content        String?       @db.Text
  contentClean   String?       @db.Text
  publishedAt    DateTime?
  language       String?

  stage          String        @default("ingest")
  status         String        @default("queued")
  retries        Int           @default(0)
  error          String?

  analysis       Json?
  relevanceScore Float?

  rankScore      Float?
  rankReason     String?

  storyId        String?

  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@unique([projectId, url])
  @@index([sourceId, stage])
  @@index([projectId, stage])
}
