{
  "name": "falak",
  "version": "1.0.0",
  "description": "Falak — YouTube competitive intelligence platform",
  "main": "src/server.js",
  "scripts": {
    "start": "prisma migrate deploy && node src/server.js",
    "dev": "nodemon src/server.js",
    "worker": "node src/worker.js",
    "ws": "node src/ws-server.js",
    "build": "prisma generate && (cd frontend && npm install && npm run build)",
    "build:server": "prisma generate",
    "delete-all-channels": "node scripts/delete-all-channels.js",
    "db:seed": "node prisma/seed.js"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "dependencies": {
    "@hocuspocus/server": "^3.4.4",
    "@prisma/client": "^5.10.0",
    "bull": "^4.16.5",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^4.18.3",
    "express-rate-limit": "^7.2.0",
    "google-auth-library": "^9.6.3",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "node-fetch": "^2.7.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "prisma": "^5.10.0",
    "uuid": "^13.0.0",
    "ws": "^8.18.0",
    "y-websocket": "^2.0.0",
    "youtube-transcript": "^1.2.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  },
  "engines": {
    "node": "20.x"
  }
}
